{
  "name": "psygil-license",
  "version": "0.1.0",
  "private": true,
  "description": "Psygil license server: device-bound subscriptions, signed JWTs, Stripe-backed fulfillment.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute psygil-license --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute psygil-license --local --file=./schema.sql",
    "keys:generate": "tsx scripts/generate-keys.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "stripe": "^18.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
